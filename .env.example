# BossBoard Environment Variables
# Copy this file to .env.local and fill in your values

# ─── Encryption ─────────────────────────────────────────────
# 32-byte hex key for encrypting agent API keys at rest.
# Auto-generated if not set (stored in ~/.bossboard/encrypt.key).
# AGENT_ENCRYPT_KEY=

# ─── Data Directory ─────────────────────────────────────────
# Override the default data directory (~/.bossboard)
# OPENCLAW_HOME=

# ─── Server ─────────────────────────────────────────────────
PORT=3000
HOSTNAME=0.0.0.0
NODE_ENV=production

# ─── Database (Postgres) ─────────────────────────────────────
# When set, switches storage from JSON files → Postgres
# DATABASE_URL=postgresql://ledgioai:ledgioai_dev_2026@192.168.2.109:5436/bossboard

# ─── Redis ───────────────────────────────────────────────────
# When set, rate limiter uses Redis instead of in-memory store
# REDIS_URL=redis://192.168.2.109:6381
