# BossBoard Environment Variables
# Copy this file to .env.local and fill in your values

# ─── Encryption ─────────────────────────────────────────────
# 32-byte hex key for encrypting agent API keys at rest.
# Auto-generated if not set (stored in ~/.bossboard/encrypt.key).
# AGENT_ENCRYPT_KEY=

# ─── Data Directory ─────────────────────────────────────────
# Override the default data directory (~/.bossboard)
# OPENCLAW_HOME=

# ─── Server ─────────────────────────────────────────────────
PORT=3000
HOSTNAME=0.0.0.0
NODE_ENV=production
